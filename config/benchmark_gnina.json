{
  "_comment": "GNINA CNN backend template. gnina does NOT use AutoGrid maps - it takes receptor + ligand + an explicit box (center/size). There is no native Windows gnina: set GNINA_LAUNCHER to 'wsl' or 'docker' on Windows, 'native' on Linux. Populate ACTIVE_IDS/DECOY_IDS with the ligand basenames in LIGAND_PDBQT_DIR.",

  "SCORING_BACKEND": "BOTH",
  "GNINA_MODE": "dock",
  "GNINA_MINIMIZE": true,
  "GNINA_SEED": 42,
  "GNINA_EXHAUSTIVENESS": 32,
  "GNINA_NUM_MODES": 9,
  "GNINA_ENERGY_RANGE": 3.0,
  "GNINA_CNN_MODEL": "default",
  "GNINA_CNN_SCORING": "rescore",
  "GNINA_DEVICE": "0",
  "GNINA_SCORE_ONLY": false,
  "COMPARE_BACKENDS": true,

  "GNINA_BINARY": "gnina",
  "GNINA_LAUNCHER": "native",
  "GNINA_DOCKER_IMAGE": "gnina/gnina:latest",

  "BENCH_DIR": "./examples/p38a_benchmark",
  "RECEPTOR_PDBQT": "./examples/p38a_benchmark/receptor.pdbqt",
  "LIGAND_PDBQT_DIR": "./examples/p38a_benchmark/ligands_pdbqt",
  "AUTODOCK_DLG_DIR": "./examples/p38a_output",
  "GNINA_OUTPUT_DIR": "./examples/gnina_output",
  "FIGURE_DIR": "./examples/figures",

  "BOX_CENTER": [0.0, 0.0, 0.0],
  "BOX_SIZE": 24.0,
  "NATIVE_RG": null,
  "CHARGE_CAP": 1.0,
  "RG_FACTOR": 1.5,
  "AUTODOCK_AUC": 0.473,

  "ACTIVE_IDS": [],
  "DECOY_IDS": []
