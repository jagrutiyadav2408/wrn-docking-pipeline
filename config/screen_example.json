{
  "_comment": "Prospective screen template: a LOCAL receptor + a directory of pre-built 3D .mol2 conformers. Unlabelled library -> ranked hit list (no ROC). Copy this, point the paths at your data, and run: python scripts/run_screen.py --config <your.json>",

  "target": {
    "pdb_id": "MYTARGET",
    "pdb_path": "./examples/custom_target/receptor.pdb",
    "native_ligand_name": "LIG",
    "chains_to_keep": ["A"],
    "search_mode": "MATCH_INBUILT",
    "box_buffer_angstroms": 4.0,
    "grid_spacing": 0.375
  },
  "ligands": {
    "source": "MOL2_DIR",
    "path": "./examples/custom_target/ligands_mol2",
    "subset_size": null,
    "active_decoy_ratio": null,
    "stratify_by": null,
    "random_seed": 42
  },
  "docking": {
    "backend": "AUTODOCK",
    "runs_per_ligand": 100,
    "heuristics": true,
    "autostop": true,
    "cluster_rmsd_threshold": 2.0,
    "pose_selection": "lowest_energy",
    "seed": 42,
    "consensus_runs": 3,
    "stability_top_n": 20,
    "deterministic": true
  },
  "quality": {
    "charge_cap": 1.0,
    "rg_factor": 1.5
  },
  "admet": {
    "mode": "NONE",
    "top_n": null
  },
  "output": {
    "benchmark_dir": "./examples/custom_target/work",
    "output_dir": "./examples/custom_target/output",
    "generate_figures": true,
    "save_intermediates": true
  },
  "hardware": {
    "gpu_device": 0,
    "n_workers": 4
  }
}
